{
  "name": "docusaurus",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "node scripts/generate-gallery-data.js && docusaurus start",
    "build": "node scripts/generate-gallery-data.js && docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "generate-gallery": "node scripts/generate-gallery-data.js",
    "migrate-galleries": "node ../scripts/migrate-old-galleries.js",
    "cleanup-migration": "node ../scripts/cleanup-migration.js"
  },
  "dependencies": {
    "@docusaurus/core": "^3.8.1",
    "@docusaurus/preset-classic": "^3.8.1",
    "@docusaurus/theme-mermaid": "^3.8.1",
    "@mdx-js/react": "^3.1.0",
    "clsx": "^1.2.1",
    "prism-react-renderer": "^1.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^4.11.0",
    "react-photo-album": "^3.1.0",
    "yet-another-react-lightbox": "^3.25.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^2.4.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=16.14"
  }
